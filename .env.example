# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# GitHub App (create at https://github.com/settings/apps)
GITHUB_APP_ID=123456
# Local dev: point at a PEM file on disk.
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.pem
# Production (Fly/etc): paste the raw PEM contents into this env var instead.
# Either literal newlines or \n escapes work. GITHUB_APP_PRIVATE_KEY wins when both are set.
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Langfuse (self-hosted, local via docker-compose)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Redis (job queue)
REDIS_URL=redis://localhost:6379/0

# Postgres (app metadata)
DATABASE_URL=postgresql://checkmate:checkmate@localhost:5432/checkmate

# App
APP_ENV=development
LOG_LEVEL=INFO
CLAUDE_MODEL=claude-sonnet-4-6
